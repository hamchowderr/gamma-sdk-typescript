{
  "name": "@hamchowderr/gamma-sdk",
  "version": "1.0.0",
  "description": "TypeScript SDK for the Gamma API",
  "repository": {
    "type": "git",
    "url": "https://github.com/hamchowderr/gamma-sdk-typescript.git"
  },
  "homepage": "https://github.com/hamchowderr/gamma-sdk-typescript",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "gamma",
    "api",
    "sdk",
    "presentation",
    "document",
    "typescript"
  ],
  "author": "hamchowderr <tylan@otakusolutions.io>",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "dotenv": "^17.2.4",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}
